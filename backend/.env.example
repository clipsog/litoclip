# Server
PORT=37373
NODE_ENV=development

# Frontend origin (for CORS and OAuth redirects)
FRONTEND_ORIGIN=http://localhost:5500
# Optional: serve frontend from backend (same-origin). Path to shardcreators.com, e.g. ../shardcreators.com
# FRONTEND_PATH=

# JWT (REQUIRED in production: set a strong secret or server will not start)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (path relative to backend folder; use absolute path in production)
DATABASE_PATH=./data.db

# Discord OAuth - create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:37373/auth/discord/callback

# Google OAuth - create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:37373/auth/google/callback

# Stripe - https://dashboard.stripe.com/apikeys (use live keys in production)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal - https://developer.paypal.com/dashboard/ (use live credentials + PAYPAL_MODE=live in production)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Crypto (wallet addresses for manual/crypto payments)
CRYPTO_BTC_ADDRESS=
CRYPTO_ETH_ADDRESS=
CRYPTO_USDT_ADDRESS=
CRYPTO_NETWORK=ethereum
